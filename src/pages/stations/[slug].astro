---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const stations = await getCollection('stations');
  return stations.map((station) => ({
    params: { slug: station.slug },
    props: { station },
  }));
}

const { station } = Astro.props;
const { Content } = await station.render();

const allStations = await getCollection('stations');
const similar = allStations
  .filter((s) => s.slug !== station.slug && s.data.format === station.data.format)
  .slice(0, 4);

const SITE_URL = 'https://worldradiostations.org';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'RadioStation',
  name: station.data.name,
  description: station.data.description,
  ...(station.data.founded ? { foundingDate: station.data.founded } : {}),
  ...(station.data.owner ? { parentOrganization: { '@type': 'Organization', name: station.data.owner } } : {}),
  ...(station.data.headquarters ? { areaServed: { '@type': 'Country', name: station.data.country }, address: { '@type': 'PostalAddress', addressLocality: station.data.headquarters, addressCountry: station.data.country } } : {}),
  ...(station.data.website ? { url: station.data.website } : {}),
  ...(station.data.slogan ? { slogan: station.data.slogan } : {}),
  inLanguage: station.data.language === 'English' ? 'en' : station.data.language,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/stations/${station.slug}`,
  },
};
---
<Base
  title={`${station.data.name} — information, frequencies, history`}
  description={station.data.description}
  jsonLd={jsonLd}
>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Stations', href: '/stations' },
    { label: station.data.name },
  ]} />

  <article class="container legal blog-post">
    <h1>{station.data.name}</h1>

    <div class="station-infobox">
      <table>
        {station.data.format && <tr><th>Format</th><td>{station.data.format}</td></tr>}
        {station.data.founded && <tr><th>Founded</th><td>{station.data.founded}</td></tr>}
        {station.data.owner && <tr><th>Owner</th><td>{station.data.owner}</td></tr>}
        {station.data.headquarters && <tr><th>Headquarters</th><td>{station.data.headquarters}</td></tr>}
        {station.data.slogan && <tr><th>Slogan</th><td><em>{station.data.slogan}</em></td></tr>}
        {station.data.frequencies.length > 0 && (
          <tr><th>Frequencies</th><td>{station.data.frequencies.join(', ')}</td></tr>
        )}
        {station.data.website && (
          <tr><th>Website</th><td><a href={station.data.website} target="_blank" rel="noopener noreferrer">{station.data.website.replace('https://', '')}</a></td></tr>
        )}
        <tr><th>Language</th><td>{station.data.language}</td></tr>
        <tr><th>Country</th><td>{station.data.country}</td></tr>
      </table>
    </div>

    <Content />

    {similar.length > 0 && (
      <div class="similar-stations">
        <h2>Similar stations</h2>
        <div class="station-directory" style="margin-bottom:2rem;">
          {similar.map((s) => (
            <a href={`/stations/${s.slug}`} class="blog-card">
              <div class="blog-card-body">
                <div class="blog-card-tags">
                  <span class="tag-chip">{s.data.format}</span>
                </div>
                <h3>{s.data.name}</h3>
                <p>{s.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="blog-cta">
      <p>Look for {station.data.name} in our web player, or listen directly from the station’s official site.</p>
      <div class="hero-ctas">
        <a class="cta cta-secondary" href="/#player">Search in the player</a>
        {station.data.website && (
          <a class="cta cta-secondary" href={station.data.website} target="_blank" rel="noopener noreferrer">Official site</a>
        )}
        <a class="cta cta-secondary" href="/stations">All stations</a>
      </div>
    </div>
  </article>
</Base>
