---
import Base from '../layouts/Base.astro';
import RadioPlayer from '../components/RadioPlayer.astro';
---
<Base title="History — World Radio Stations" description="The radio stations you listened to most recently. Quickly return to a station you heard a moment ago." noindex={true}>
  <section class="container page-head">
    <h1>History</h1>
    <p class="page-sub">The stations you played most recently.</p>
  </section>

  <section class="container player-section">
    <RadioPlayer mode="history" showSearch={true} />
  </section>
</Base>
