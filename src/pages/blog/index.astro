---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const getReadingTime = (body: string) => Math.max(1, Math.round((body || '').split(/\s+/).filter(Boolean).length / 200));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Blog — World Radio Stations',
  description: 'Articles about radio around the world, music and internet streaming.',
  inLanguage: 'en',
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.date,
    author: { '@type': 'Person', name: p.data.author },
  })),
};
---
<Base
  title="Blog — World Radio Stations"
  description="Articles about radio around the world, the music scene, internet streaming and tips for listeners."
  jsonLd={jsonLd}
>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Blog' },
  ]} />

  <section class="container blog-index">
    <div class="section-head">
      <h1>Blog</h1>
      <p>Articles about radio around the world, music and useful tips for listeners.</p>
    </div>

    <div class="blog-grid">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="blog-card-body">
            <div class="blog-card-tags">
              {post.data.tags.map((tag) => (
                <span class="tag-chip">{tag}</span>
              ))}
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <time datetime={post.data.date}>
              {new Date(post.data.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span> · {getReadingTime(post.body)} min read</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
