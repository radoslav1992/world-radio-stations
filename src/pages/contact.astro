---
import Base from '../layouts/Base.astro';

const EMAIL = 'info@worldradiostations.org';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact — World Radio Stations',
  inLanguage: 'en',
};
---
<Base
  title="Contact — World Radio Stations"
  description="Have a question, feedback or want to report a broken station? Get in touch."
  jsonLd={jsonLd}
>
  <article class="legal container">
    <h1>Contact</h1>
    <p class="updated">We usually reply within 1–3 business days.</p>

    <h2>Email</h2>
    <p>
      The fastest way to reach us is by email:
    </p>
    <p class="contact-email">
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
    </p>

    <h2>What to write to us about</h2>
    <ul>
      <li><strong>Broken station</strong> — tell us its name and what you see (an error, silence, something else).</li>
      <li><strong>Missing station</strong> — send the name and the stream URL if you know it. We’ll add it to Radio Browser.</li>
      <li><strong>App bug</strong> — your phone model, Android version and a short description of what happened.</li>
      <li><strong>Feature request</strong> — we always welcome ideas.</li>
      <li><strong>Data deletion request</strong> — even though we don’t store data on a server, if you have a GDPR question, write to us.</li>
      <li><strong>Advertising / partnerships</strong> — drop us a short note about what you have in mind.</li>
    </ul>

    <h2>What we can’t do</h2>
    <ul>
      <li>We don’t control what the stations broadcast. If a station airs something you don’t like, please contact the station itself.</li>
      <li>We’re not an authorized representative of any station.</li>
      <li>We don’t offer music recommendations, playlists or DJ services.</li>
    </ul>

    <h2>Response time</h2>
    <p>
      This is a spare-time project, so replies usually come within 1–3 business days. Thanks for
      your patience.
    </p>
  </article>
</Base>
