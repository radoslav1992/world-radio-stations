---
import Base from '../layouts/Base.astro';
import RadioPlayer from '../components/RadioPlayer.astro';
---
<Base title="Favorite stations — World Radio Stations" description="Quick access to your saved radio stations from around the world. Listen to your favorites for free online." noindex={true}>
  <section class="container page-head">
    <h1>Favorite stations</h1>
    <p class="page-sub">Your saved radio stations.</p>
  </section>

  <section class="container player-section">
    <RadioPlayer mode="favorites" showSearch={true} />
  </section>
</Base>
