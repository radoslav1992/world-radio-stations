---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { MOODS } from '../../data/moods';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Radio by mood & activity',
  description: 'Curated radio collections for focus, sleep, working out, coding and more — streaming free from stations around the world.',
  inLanguage: 'en',
};
---
<Base
  title="Radio by mood & activity — Focus, Sleep, Workout, Coding"
  description="Curated radio collections for focus, sleep, working out, coding, jazz and chilling out — free streaming stations from around the world."
  jsonLd={jsonLd}
>
  <Breadcrumbs crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Discover' },
  ]} />

  <section class="container blog-index">
    <div class="section-head">
      <h1>Radio by mood</h1>
      <p>Not sure what to play? Start from a vibe. Each collection pulls stations from around the world that fit the moment.</p>
    </div>

    <div class="mood-grid">
      {MOODS.map((m) => (
        <a href={`/moods/${m.slug}`} class="mood-card">
          <span class="mood-emoji" aria-hidden="true">{m.emoji}</span>
          <h2>{m.title}</h2>
          <p>{m.blurb}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
